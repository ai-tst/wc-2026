# Скопируй в .env и заполни. .env в git не коммитится (см. .gitignore).

# PostgreSQL. Если не задано — приложение использует локальный SQLite (local_dev.db).
DATABASE_URL=postgresql://user:password@localhost:5432/wctournament

# Подпись сессионных куки. Любая случайная строка 32+ символов.
SECRET_KEY=

# Ключ к API sstats.net (матчи и рейтинги игроков).
SSTATS_API_KEY=

# Токен Telegram-бота от @BotFather. Оставь пустым, если бот не нужен.
TELEGRAM_BOT_TOKEN=

# Порт для локального запуска (по умолчанию 3000). На проде не используется (gunicorn --bind).
PORT=3000
